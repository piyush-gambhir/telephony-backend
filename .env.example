# Telephony Backend — environment configuration
#
# The repo is provider-agnostic. For each capability, choose the active
# provider via PROVIDER_<CAPABILITY> (twilio | vonage | plivo | messagebird).
# Different capabilities can use different providers — they're independent.

# ── Active provider per capability ─────────────────────────────────────────
PROVIDER_SMS=twilio
PROVIDER_VOICE=twilio
PROVIDER_VERIFY=twilio
PROVIDER_LOOKUP=twilio
PROVIDER_NUMBERS=twilio
PROVIDER_MESSAGING_SERVICES=twilio
PROVIDER_CONVERSATIONS=twilio

# ── Twilio credentials ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional: override the auth token used to validate inbound webhook signatures
TWILIO_WEBHOOK_AUTH_TOKEN=

# ── Vonage credentials (placeholder; provider not yet implemented) ─────────
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_APPLICATION_ID=
# VONAGE_PRIVATE_KEY=

# ── Plivo credentials (placeholder) ────────────────────────────────────────
# PLIVO_AUTH_ID=
# PLIVO_AUTH_TOKEN=

# ── MessageBird credentials (placeholder) ──────────────────────────────────
# MESSAGEBIRD_ACCESS_KEY=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
